<Window x:Class="CyberSecurityChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Chatbot"
        Height="520" Width="800"
        Background="#1E1E1E">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- HIDDEN MEDIA PLAYER FOR VOICE GREETING -->
        <MediaElement Name="mediaPlayer"
                      Visibility="Collapsed"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      Volume="1.0"/>

        <!-- CHAT AREA -->
        <RichTextBox Name="rtbChat"
                     Grid.Row="0"
                     IsReadOnly="True"
                     Background="#252526"
                     Foreground="White"
                     FontFamily="Consolas"
                     FontSize="7"
                     VerticalScrollBarVisibility="Auto"/>

        <!-- INPUT AREA -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">

            <TextBox Name="txtInput"
                     Width="650"
                     Height="30"
                     Background="#3C3C3C"
                     Foreground="White"/>

            <Button Content="Send"
                    Width="100"
                    Margin="10,0,0,0"
                    Click="btnSend_Click"/>

        </StackPanel>

    </Grid>
</Window>